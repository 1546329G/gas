
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MisFinanzas — Control Total</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0e0c;
    --surface: #1a1917;
    --card: #222120;
    --border: #333230;
    --accent: #e8c547;
    --accent2: #4ade80;
    --danger: #f87171;
    --text: #f0ece4;
    --muted: #7a766e;
    --font-mono: 'Space Mono', monospace;
    --font-serif: 'Fraunces', serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HEADER */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky; top: 0; z-index: 100;
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -1px;
  }
  .logo span { color: var(--text); font-weight: 300; font-style: italic; }

  nav { display: flex; gap: 0.5rem; }
  .tab-btn {
    padding: 0.4rem 1rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* MAIN */
  main { max-width: 1100px; margin: 0 auto; padding: 2rem; }

  .section { display: none; }
  .section.active { display: block; }

  /* STATS ROW */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    animation: fadeUp 0.4s ease both;
  }
  .stat-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
  }
  .stat-card.income::before { background: var(--accent2); }
  .stat-card.expense::before { background: var(--danger); }
  .stat-card.balance::before { background: var(--accent); }

  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .stat-value {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }
  .stat-card.income .stat-value { color: var(--accent2); }
  .stat-card.expense .stat-value { color: var(--danger); }
  .stat-card.balance .stat-value { color: var(--accent); }

  /* GRID */
  .grid-2 { display: grid; grid-template-columns: 1fr 1.4fr; gap: 1.5rem; }

  /* FORM */
  .panel {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.5rem;
    animation: fadeUp 0.5s ease both;
  }
  .panel-title {
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.3rem;
    margin-top: 0.9rem;
  }
  label:first-of-type { margin-top: 0; }

  input, select, textarea {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.6rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
  }
  input:focus, select:focus { border-color: var(--accent); }
  select option { background: var(--bg); }

  .type-toggle {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0.5rem; margin-top: 0.3rem;
  }
  .type-btn {
    padding: 0.6rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.2s;
  }
  .type-btn.active-income { background: var(--accent2); color: var(--bg); border-color: var(--accent2); }
  .type-btn.active-expense { background: var(--danger); color: #fff; border-color: var(--danger); }

  .btn-add {
    width: 100%;
    margin-top: 1.2rem;
    padding: 0.8rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-add:hover { opacity: 0.85; }

  /* TRANSACTIONS LIST */
  .tx-list { display: flex; flex-direction: column; gap: 0; }
  .tx-filter {
    display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;
  }
  .filter-btn {
    padding: 0.3rem 0.8rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn.active, .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .tx-item {
    display: flex;
    align-items: center;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    animation: fadeUp 0.3s ease both;
  }
  .tx-item:hover { background: var(--surface); }
  .tx-cat {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    margin-right: 1rem;
    flex-shrink: 0;
  }
  .tx-info { flex: 1; min-width: 0; }
  .tx-desc {
    font-size: 0.85rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .tx-meta {
    font-size: 0.65rem;
    color: var(--muted);
    margin-top: 2px;
  }
  .tx-amount {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    margin-right: 0.75rem;
  }
  .tx-amount.income { color: var(--accent2); }
  .tx-amount.expense { color: var(--danger); }
  .tx-del {
    background: none; border: none;
    color: var(--border); cursor: pointer;
    font-size: 1rem; padding: 0.2rem 0.4rem;
    transition: color 0.2s;
  }
  .tx-del:hover { color: var(--danger); }

  /* BUDGET */
  .budget-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .budget-card {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 1.25rem;
    animation: fadeUp 0.4s ease both;
  }
  .budget-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; }
  .budget-cat { font-size: 0.85rem; }
  .budget-amounts { font-size: 0.7rem; color: var(--muted); text-align: right; }
  .budget-bar-bg {
    height: 6px; background: var(--border); border-radius: 0;
    overflow: hidden;
  }
  .budget-bar-fill {
    height: 100%; transition: width 0.5s ease;
    border-radius: 0;
  }
  .budget-ok { background: var(--accent2); }
  .budget-warn { background: var(--accent); }
  .budget-over { background: var(--danger); }
  .budget-pct { font-size: 0.65rem; color: var(--muted); margin-top: 0.4rem; }

  /* CHARTS */
  .chart-wrap { position: relative; height: 180px; margin-top: 1rem; }
  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 100%;
    padding-bottom: 20px;
  }
  .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .bar {
    width: 100%;
    min-height: 2px;
    position: relative;
    transition: height 0.5s ease;
  }
  .bar-label { font-size: 0.6rem; color: var(--muted); white-space: nowrap; }

  /* PERIOD SELECTOR */
  .period-row {
    display: flex; gap: 0.5rem; align-items: center; margin-bottom: 1.5rem;
  }
  .period-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-right: 0.5rem; }

  /* EMPTY */
  .empty-state {
    text-align: center; padding: 3rem 1rem;
    color: var(--muted); font-size: 0.8rem; letter-spacing: 1px;
  }
  .empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 700px) {
    .stats-row { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: 1fr; }
    .budget-grid { grid-template-columns: 1fr; }
    nav { flex-wrap: wrap; }
    header { flex-direction: column; gap: 1rem; align-items: flex-start; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">Mis<span>Finanzas</span></div>
  <nav>
    <button class="tab-btn active" onclick="showTab('dashboard')">Dashboard</button>
    <button class="tab-btn" onclick="showTab('gastos')">Gastos</button>
    <button class="tab-btn" onclick="showTab('presupuesto')">Presupuesto</button>
  </nav>
</header>

<main>

  <!-- DASHBOARD -->
  <div id="tab-dashboard" class="section active">
    <div class="period-row">
      <span class="period-label">Ver:</span>
      <button class="filter-btn active" onclick="setPeriod('dia', this)">Hoy</button>
      <button class="filter-btn" onclick="setPeriod('semana', this)">Esta semana</button>
      <button class="filter-btn" onclick="setPeriod('mes', this)">Este mes</button>
      <button class="filter-btn" onclick="setPeriod('todo', this)">Todo</button>
    </div>

    <div class="stats-row">
      <div class="stat-card income">
        <div class="stat-label">Ingresos</div>
        <div class="stat-value" id="stat-income">S/ 0.00</div>
      </div>
      <div class="stat-card expense">
        <div class="stat-label">Gastos</div>
        <div class="stat-value" id="stat-expense">S/ 0.00</div>
      </div>
      <div class="stat-card balance">
        <div class="stat-label">Balance</div>
        <div class="stat-value" id="stat-balance">S/ 0.00</div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title">Últimas transacciones</div>
      <div id="dash-tx-list" class="tx-list"></div>
    </div>
  </div>

  <!-- GASTOS -->
  <div id="tab-gastos" class="section">
    <div class="grid-2">
      <div class="panel">
        <div class="panel-title">Nueva transacción</div>

        <label>Tipo</label>
        <div class="type-toggle">
          <button class="type-btn active-expense" id="btn-gasto" onclick="setType('gasto')">— Gasto</button>
          <button class="type-btn" id="btn-ingreso" onclick="setType('ingreso')">+ Ingreso</button>
        </div>

        <label>Descripción</label>
        <input type="text" id="tx-desc" placeholder="Ej: Almuerzo, taxi, salario...">

        <label>Monto (S/)</label>
        <input type="number" id="tx-amount" placeholder="0.00" min="0" step="0.01">

        <label>Categoría</label>
        <select id="tx-cat">
          <option value="🍔 Comida">🍔 Comida</option>
          <option value="🚌 Transporte">🚌 Transporte</option>
          <option value="🏠 Vivienda">🏠 Vivienda</option>
          <option value="💊 Salud">💊 Salud</option>
          <option value="🎮 Entretenimiento">🎮 Entretenimiento</option>
          <option value="👕 Ropa">👕 Ropa</option>
          <option value="📚 Educación">📚 Educación</option>
          <option value="💼 Trabajo/Ingresos">💼 Trabajo/Ingresos</option>
          <option value="🛒 Supermercado">🛒 Supermercado</option>
          <option value="💡 Servicios">💡 Servicios</option>
          <option value="📱 Tecnología">📱 Tecnología</option>
          <option value="🎁 Otros">🎁 Otros</option>
        </select>

        <label>Fecha</label>
        <input type="date" id="tx-date">

        <button class="btn-add" onclick="addTransaction()">+ Agregar</button>
      </div>

      <div class="panel">
        <div class="panel-title">Historial</div>
        <div class="tx-filter">
          <button class="filter-btn active" onclick="filterTx('todo', this)">Todos</button>
          <button class="filter-btn" onclick="filterTx('gasto', this)">Gastos</button>
          <button class="filter-btn" onclick="filterTx('ingreso', this)">Ingresos</button>
        </div>
        <div id="tx-list" class="tx-list"></div>
      </div>
    </div>
  </div>

  <!-- PRESUPUESTO -->
  <div id="tab-presupuesto" class="section">
    <div class="grid-2">
      <div class="panel">
        <div class="panel-title">Definir presupuesto mensual</div>

        <label>Categoría</label>
        <select id="bud-cat">
          <option>🍔 Comida</option>
          <option>🚌 Transporte</option>
          <option>🏠 Vivienda</option>
          <option>💊 Salud</option>
          <option>🎮 Entretenimiento</option>
          <option>👕 Ropa</option>
          <option>📚 Educación</option>
          <option>🛒 Supermercado</option>
          <option>💡 Servicios</option>
          <option>📱 Tecnología</option>
          <option>🎁 Otros</option>
        </select>

        <label>Límite mensual (S/)</label>
        <input type="number" id="bud-limit" placeholder="0.00" min="0" step="0.01">

        <button class="btn-add" onclick="addBudget()">Guardar presupuesto</button>
      </div>

      <div class="panel">
        <div class="panel-title">Estado del presupuesto — este mes</div>
        <div id="budget-list" class="budget-grid"></div>
      </div>
    </div>
  </div>

</main>

<script>
let transactions = JSON.parse(localStorage.getItem('mf_tx') || '[]');
let budgets = JSON.parse(localStorage.getItem('mf_bud') || '{}');
let txType = 'gasto';
let txFilter = 'todo';
let period = 'dia';

// init date
document.getElementById('tx-date').valueAsDate = new Date();

function save() {
  localStorage.setItem('mf_tx', JSON.stringify(transactions));
  localStorage.setItem('mf_bud', JSON.stringify(budgets));
}

function setType(t) {
  txType = t;
  document.getElementById('btn-gasto').className = 'type-btn' + (t === 'gasto' ? ' active-expense' : '');
  document.getElementById('btn-ingreso').className = 'type-btn' + (t === 'ingreso' ? ' active-income' : '');
}

function addTransaction() {
  const desc = document.getElementById('tx-desc').value.trim();
  const amount = parseFloat(document.getElementById('tx-amount').value);
  const cat = document.getElementById('tx-cat').value;
  const date = document.getElementById('tx-date').value;
  if (!desc || !amount || amount <= 0 || !date) return alert('Completa todos los campos');
  transactions.unshift({ id: Date.now(), desc, amount, cat, date, type: txType });
  save();
  document.getElementById('tx-desc').value = '';
  document.getElementById('tx-amount').value = '';
  renderAll();
}

function delTransaction(id) {
  transactions = transactions.filter(t => t.id !== id);
  save(); renderAll();
}

function addBudget() {
  const cat = document.getElementById('bud-cat').value;
  const limit = parseFloat(document.getElementById('bud-limit').value);
  if (!limit || limit <= 0) return alert('Ingresa un límite válido');
  budgets[cat] = limit;
  save(); renderBudget();
}

function filterTx(f, btn) {
  txFilter = f;
  document.querySelectorAll('.tx-filter .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderTxList();
}

function setPeriod(p, btn) {
  period = p;
  document.querySelectorAll('.period-row .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderDashboard();
}

function showTab(tab) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  event.target.classList.add('active');
  renderAll();
}

function filterByPeriod(txs) {
  const now = new Date();
  return txs.filter(t => {
    const d = new Date(t.date);
    if (period === 'dia') return d.toDateString() === now.toDateString();
    if (period === 'semana') {
      const start = new Date(now); start.setDate(now.getDate() - now.getDay());
      return d >= start;
    }
    if (period === 'mes') return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
    return true;
  });
}

function fmt(n) { return 'S/ ' + n.toFixed(2); }

function renderDashboard() {
  const filtered = filterByPeriod(transactions);
  const income = filtered.filter(t => t.type === 'ingreso').reduce((a, t) => a + t.amount, 0);
  const expense = filtered.filter(t => t.type === 'gasto').reduce((a, t) => a + t.amount, 0);
  document.getElementById('stat-income').textContent = fmt(income);
  document.getElementById('stat-expense').textContent = fmt(expense);
  const bal = income - expense;
  const balEl = document.getElementById('stat-balance');
  balEl.textContent = fmt(bal);
  balEl.style.color = bal >= 0 ? 'var(--accent)' : 'var(--danger)';

  const list = document.getElementById('dash-tx-list');
  const recent = filtered.slice(0, 8);
  if (!recent.length) {
    list.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div>Sin transacciones en este período</div>`;
    return;
  }
  list.innerHTML = recent.map(t => txHTML(t)).join('');
}

function txHTML(t) {
  const emoji = t.cat.split(' ')[0];
  return `<div class="tx-item">
    <div class="tx-cat">${emoji}</div>
    <div class="tx-info">
      <div class="tx-desc">${t.desc}</div>
      <div class="tx-meta">${t.cat} · ${formatDate(t.date)}</div>
    </div>
    <div class="tx-amount ${t.type}">${t.type === 'ingreso' ? '+' : '-'}${fmt(t.amount)}</div>
    <button class="tx-del" onclick="delTransaction(${t.id})">✕</button>
  </div>`;
}

function formatDate(d) {
  const [y, m, day] = d.split('-');
  const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  return `${parseInt(day)} ${months[parseInt(m)-1]} ${y}`;
}

function renderTxList() {
  const list = document.getElementById('tx-list');
  let data = txFilter === 'todo' ? transactions : transactions.filter(t => t.type === txFilter);
  if (!data.length) {
    list.innerHTML = `<div class="empty-state"><div class="empty-icon">🗂️</div>No hay registros aún</div>`;
    return;
  }
  list.innerHTML = data.map(t => txHTML(t)).join('');
}

function renderBudget() {
  const list = document.getElementById('budget-list');
  const now = new Date();
  const monthTx = transactions.filter(t => {
    const d = new Date(t.date);
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear() && t.type === 'gasto';
  });

  if (!Object.keys(budgets).length) {
    list.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">📊</div>Define tu primer presupuesto</div>`;
    return;
  }

  list.innerHTML = Object.entries(budgets).map(([cat, limit]) => {
    const spent = monthTx.filter(t => t.cat === cat).reduce((a, t) => a + t.amount, 0);
    const pct = Math.min((spent / limit) * 100, 100);
    const cls = pct < 70 ? 'budget-ok' : pct < 90 ? 'budget-warn' : 'budget-over';
    return `<div class="budget-card">
      <div class="budget-top">
        <div class="budget-cat">${cat}</div>
        <div class="budget-amounts">${fmt(spent)} / ${fmt(limit)}</div>
      </div>
      <div class="budget-bar-bg">
        <div class="budget-bar-fill ${cls}" style="width:${pct}%"></div>
      </div>
      <div class="budget-pct">${pct.toFixed(0)}% usado</div>
    </div>`;
  }).join('');
}

function renderAll() {
  renderDashboard();
  renderTxList();
  renderBudget();
}

// Seed some example data if empty
if (!transactions.length) {
  const today = new Date().toISOString().split('T')[0];
  const yesterday = new Date(Date.now()-86400000).toISOString().split('T')[0];
  transactions = [
    { id: 1, desc: 'Salario mensual', amount: 2500, cat: '💼 Trabajo/Ingresos', date: today, type: 'ingreso' },
    { id: 2, desc: 'Almuerzo', amount: 15, cat: '🍔 Comida', date: today, type: 'gasto' },
    { id: 3, desc: 'Taxi al trabajo', amount: 8, cat: '🚌 Transporte', date: today, type: 'gasto' },
    { id: 4, desc: 'Supermercado semanal', amount: 120, cat: '🛒 Supermercado', date: yesterday, type: 'gasto' },
    { id: 5, desc: 'Internet + luz', amount: 85, cat: '💡 Servicios', date: yesterday, type: 'gasto' },
  ];
  budgets = { '🍔 Comida': 400, '🚌 Transporte': 150, '🛒 Supermercado': 500, '💡 Servicios': 200, '🎮 Entretenimiento': 100 };
  save();
}

renderAll();
</script>
</body>
</html>
